# Database connection (Railway MySQL)
DATABASE_URL="mysql://user:password@host:port/dbname"

# JWT Secret - 必须生成一个密码学安全的随机字符串（至少32字符）
# 生成方法: node -e "console.log(require('crypto').randomBytes(64).toString('base64url'))"
JWT_SECRET=""

# CORS 白名单 - 允许的前端域名（逗号分隔，不含尾斜杠）
CORS_ALLOWED_ORIGINS="https://www.ethscam.com,https://ethscam.com"

# Redis URL（可选，用于分布式速率限制）
# Railway: 添加 Redis 插件后会自动注入此变量
# REDIS_URL="redis://..."

# Vercel Blob 存储（图片上传必须）
# 在 Vercel 控制台 → Storage 中创建 Blob Store，会自动注入此变量
# BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# 安全日志级别: off, basic, verbose
SECURITY_LOG_LEVEL="basic"
